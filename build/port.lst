 299:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 
 300:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		/* Determine the maximum priority from which ISR safe FreeRTOS API
 301:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		functions can be called.  ISR safe functions are those that end in
 302:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		"FromISR".  FreeRTOS maintains separate thread and ISR API functions to
 303:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		ensure interrupt entry is as fast and simple as possible.
 304:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 
 305:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		Save the interrupt priority value that is about to be clobbered. */
 306:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		ulOriginalPriority = *pucFirstUserPriorityRegister;
 307:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 
 308:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		/* Determine the number of priority bits available.  First write to all
 309:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		possible bits. */
