 311:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 
 312:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		/* Read the value back to see how many bits stuck. */
 313:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		ucMaxPriorityValue = *pucFirstUserPriorityRegister;
 314:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 
 315:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		/* Use the same mask on the maximum system call priority. */
 316:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		ucMaxSysCallPriority = configMAX_SYSCALL_INTERRUPT_PRIORITY & ucMaxPriorityValue;
 317:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 
 318:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		/* Calculate the maximum acceptable priority group value for the number
 319:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		of bits read back. */
 320:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		ulMaxPRIGROUPValue = portMAX_PRIGROUP_BITS;
 321:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		while( ( ucMaxPriorityValue & portTOP_BIT_OF_BYTE ) == portTOP_BIT_OF_BYTE )
 322:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		{
 323:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 			ulMaxPRIGROUPValue--;
 324:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 			ucMaxPriorityValue <<= ( uint8_t ) 0x01;
 325:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		}
 326:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 
 327:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		/* Shift the priority group value back to its position within the AIRCR
 328:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		register. */
 329:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		ulMaxPRIGROUPValue <<= portPRIGROUP_SHIFT;
 330:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		ulMaxPRIGROUPValue &= portPRIORITY_GROUP_MASK;
 331:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 
 332:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		/* Restore the clobbered interrupt priority register to its original
 333:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		value. */
 334:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		*pucFirstUserPriorityRegister = ulOriginalPriority;
 335:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 	}
