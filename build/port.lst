 673:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		/* Priority grouping:  The interrupt controller (NVIC) allows the bits
 674:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		that define each interrupt's priority to be split between bits that
 675:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		define the interrupt's pre-emption priority bits and bits that define
 676:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		the interrupt's sub-priority.  For simplicity all bits must be defined
 677:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		to be pre-emption priority bits.  The following assertion will fail if
 678:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		this is not the case (if some bits represent a sub-priority).
 679:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 
 680:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		If the application only uses CMSIS libraries for interrupt
 681:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		configuration then the correct setting can be achieved on all Cortex-M
 682:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		devices by calling NVIC_SetPriorityGrouping( 0 ); before starting the
 683:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		scheduler.  Note however that some vendor specific peripheral libraries
 684:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		assume a non-zero priority group setting, in which cases using a value
 685:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		of zero will result in unpredicable behaviour. */
 686:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 		configASSERT( ( portAIRCR_REG & portPRIORITY_GROUP_MASK ) <= ulMaxPRIGROUPValue );
