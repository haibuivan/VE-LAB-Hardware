 214:FreeRTOS/portable/GCC/ARM_CM3/port.c ****  * See header file for description.
 215:FreeRTOS/portable/GCC/ARM_CM3/port.c ****  */
 216:FreeRTOS/portable/GCC/ARM_CM3/port.c **** StackType_t *pxPortInitialiseStack( StackType_t *pxTopOfStack, TaskFunction_t pxCode, void *pvParam
 217:FreeRTOS/portable/GCC/ARM_CM3/port.c **** {
 218:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 	/* Simulate the stack frame as it would be created by a context switch
 219:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 	interrupt. */
 220:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 	pxTopOfStack--; /* Offset added to account for the way the MCU uses the stack on entry/exit of int
 221:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 	*pxTopOfStack = portINITIAL_XPSR;	/* xPSR */
 222:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 	pxTopOfStack--;
 223:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 	*pxTopOfStack = ( ( StackType_t ) pxCode ) & portSTART_ADDRESS_MASK;	/* PC */
 224:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 	pxTopOfStack--;
 225:FreeRTOS/portable/GCC/ARM_CM3/port.c **** 	*pxTopOfStack = ( StackType_t ) portTASK_RETURN_ADDRESS;	/* LR */
