  87:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h ****  #include <stdint.h>
  88:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 
  89:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** /* Type definitions. */
  90:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** #define portCHAR		char
  91:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** #define portFLOAT		float
  92:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** #define portDOUBLE		double
  93:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** #define portLONG		long
  94:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** #define portSHORT		short
  95:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** #define portSTACK_TYPE	uint32_t
  96:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** #define portBASE_TYPE	long
  97:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 
  98:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** typedef portSTACK_TYPE StackType_t;
  99:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** typedef long BaseType_t;
 100:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** typedef unsigned long UBaseType_t;
 101:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 
 102:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** #if( configUSE_16_BIT_TICKS == 1 )
 103:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 	typedef uint16_t TickType_t;
 104:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 	#define portMAX_DELAY ( TickType_t ) 0xffff
 105:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** #else
 106:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 	typedef uint32_t TickType_t;
 107:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 	#define portMAX_DELAY ( TickType_t ) 0xffffffffUL
 108:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 
 109:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 	/* 32-bit tick type on a 32-bit architecture, so reads of the tick count do
 110:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 	not need to be guarded with a critical section. */
 111:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 	#define portTICK_TYPE_IS_ATOMIC 1
