 120:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 
 121:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** /* Scheduler utilities. */
 122:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** #define portYIELD() 															\
 123:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** {																				\
 124:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 	/* Set a PendSV to request a context switch. */								\
 125:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 	portNVIC_INT_CTRL_REG = portNVIC_PENDSVSET_BIT;								\
 126:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 																				\
 127:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 	/* Barriers are normally not required but do ensure the code is completely	\
 128:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 	within the specified behaviour for the architecture. */						\
 129:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 	__asm volatile( "dsb" );													\
 130:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** 	__asm volatile( "isb" );													\
 131:FreeRTOS/portable/GCC/ARM_CM3/portmacro.h **** }
