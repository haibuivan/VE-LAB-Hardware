 134:FreeRTOS/source/tasks.c **** a statically allocated stack and a dynamically allocated TCB. */
 135:FreeRTOS/source/tasks.c **** #define tskSTATIC_AND_DYNAMIC_ALLOCATION_POSSIBLE ( ( ( configSUPPORT_STATIC_ALLOCATION == 1 ) && (
