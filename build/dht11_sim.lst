  84:Sensor/dht11_sim.c ****     gpio.GPIO_Mode  = GPIO_Mode_IPU;
  85:Sensor/dht11_sim.c ****     gpio.GPIO_Speed = GPIO_Speed_50MHz;
  86:Sensor/dht11_sim.c ****     GPIO_Init(GPIOA, &gpio);
  87:Sensor/dht11_sim.c **** 
  88:Sensor/dht11_sim.c ****     /* Reset IC state, về bắt Falling edge */
  89:Sensor/dht11_sim.c ****     s.ic_edge = 0;
