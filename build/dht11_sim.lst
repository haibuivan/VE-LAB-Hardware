  94:Sensor/dht11_sim.c **** /* Schedule OC event sau `us` µs (tính từ CNT hiện tại) */
  95:Sensor/dht11_sim.c **** static inline void prv_oc_schedule(uint16_t us)
  96:Sensor/dht11_sim.c **** {
  97:Sensor/dht11_sim.c ****     TIM1->CCR1 = (uint16_t)(TIM1->CNT + us);
  98:Sensor/dht11_sim.c ****     TIM_ClearITPendingBit(TIM1, TIM_IT_CC1);
  99:Sensor/dht11_sim.c ****     TIM_ITConfig(TIM1, TIM_IT_CC1, ENABLE);
 100:Sensor/dht11_sim.c **** }
