  18:Sensor/dht11_sim.c **** 
  19:Sensor/dht11_sim.c **** /* Start signal từ host: LOW 18ms..30ms */
  20:Sensor/dht11_sim.c **** #define DHT_START_MIN  18000u
  21:Sensor/dht11_sim.c **** #define DHT_START_MAX  30000u
  22:Sensor/dht11_sim.c **** 
