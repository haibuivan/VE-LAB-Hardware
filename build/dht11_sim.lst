  67:Sensor/dht11_sim.c **** /* PA0 → Output Open-Drain (đang phát data) */
  68:Sensor/dht11_sim.c **** static void prv_pa0_tx_mode(void)
  69:Sensor/dht11_sim.c **** {
  70:Sensor/dht11_sim.c ****     GPIO_SetBits(GPIOA, GPIO_Pin_0);   /* giữ HIGH tránh glitch khi chuyển mode */
  71:Sensor/dht11_sim.c ****     GPIO_InitTypeDef gpio;
  72:Sensor/dht11_sim.c ****     gpio.GPIO_Pin   = GPIO_Pin_0;
  73:Sensor/dht11_sim.c ****     gpio.GPIO_Mode  = GPIO_Mode_Out_OD;
  74:Sensor/dht11_sim.c ****     gpio.GPIO_Speed = GPIO_Speed_50MHz;
  75:Sensor/dht11_sim.c ****     GPIO_Init(GPIOA, &gpio);
  76:Sensor/dht11_sim.c ****     GPIO_SetBits(GPIOA, GPIO_Pin_0);   /* idle HIGH */
  77:Sensor/dht11_sim.c **** }
  78:Sensor/dht11_sim.c **** 
  79:Sensor/dht11_sim.c **** /* PA0 → Input Pull-Up (chờ host) */
