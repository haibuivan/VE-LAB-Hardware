 203:Libraries/CMSIS/Include/core_cm3.h **** /**
 204:Libraries/CMSIS/Include/core_cm3.h ****   \brief  Union type to access the Application Program Status Register (APSR).
 205:Libraries/CMSIS/Include/core_cm3.h ****  */
 206:Libraries/CMSIS/Include/core_cm3.h **** typedef union
 207:Libraries/CMSIS/Include/core_cm3.h **** {
 208:Libraries/CMSIS/Include/core_cm3.h ****   struct
 209:Libraries/CMSIS/Include/core_cm3.h ****   {
 210:Libraries/CMSIS/Include/core_cm3.h ****     uint32_t _reserved0:27;              /*!< bit:  0..26  Reserved */
 211:Libraries/CMSIS/Include/core_cm3.h ****     uint32_t Q:1;                        /*!< bit:     27  Saturation condition flag */
 212:Libraries/CMSIS/Include/core_cm3.h ****     uint32_t V:1;                        /*!< bit:     28  Overflow condition code flag */
 213:Libraries/CMSIS/Include/core_cm3.h ****     uint32_t C:1;                        /*!< bit:     29  Carry condition code flag */
