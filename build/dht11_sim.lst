 102:Sensor/dht11_sim.c **** /* Lấy bit thứ bit_idx trong frame 40 bit (MSB first) */
 103:Sensor/dht11_sim.c **** static inline uint8_t prv_current_bit(void)
 104:Sensor/dht11_sim.c **** {
 105:Sensor/dht11_sim.c ****     uint8_t byte_idx = s.bit_idx >> 3;
 106:Sensor/dht11_sim.c ****     uint8_t shift    = 7u - (s.bit_idx & 0x07u);
 107:Sensor/dht11_sim.c ****     return (s.data[byte_idx] >> shift) & 0x01u;
 108:Sensor/dht11_sim.c **** }
