   1:Sensor/dht11_sim.c **** #include "dht11_sim.h"
   2:Sensor/dht11_sim.c **** 
   3:Sensor/dht11_sim.c **** /*
   4:Sensor/dht11_sim.c ****  * Timing giao thức DHT11 (đơn vị: microsecond):
   5:Sensor/dht11_sim.c ****  *
   6:Sensor/dht11_sim.c ****  *   Host start signal : kéo LOW 18–30 ms
   7:Sensor/dht11_sim.c ****  *   Sensor response   : LOW 80 µs → HIGH 80 µs (báo sẵn sàng)
   8:Sensor/dht11_sim.c ****  *   Mỗi bit dữ liệu  : LOW 50 µs → HIGH 26 µs (bit=0) hoặc 70 µs (bit=1)
   9:Sensor/dht11_sim.c ****  *   Stop bit          : LOW 50 µs → dọn bus HIGH 10 µs
  10:Sensor/dht11_sim.c ****  */
  11:Sensor/dht11_sim.c **** #define DHT_RESP_LOW 80u     /* Response: kéo LOW  80 µs */
  12:Sensor/dht11_sim.c **** #define DHT_RESP_HIGH 80u    /* Response: kéo HIGH 80 µs */
  13:Sensor/dht11_sim.c **** #define DHT_BIT_LOW 50u      /* Preamble mỗi bit: LOW 50 µs */
  14:Sensor/dht11_sim.c **** #define DHT_BIT_0_HIGH 26u   /* Bit-0: HIGH 26 µs */
  15:Sensor/dht11_sim.c **** #define DHT_BIT_1_HIGH 70u   /* Bit-1: HIGH 70 µs */
  16:Sensor/dht11_sim.c **** #define DHT_STOP_LOW 50u     /* Stop bit: LOW 50 µs */
  17:Sensor/dht11_sim.c **** #define DHT_STOP_CLEANUP 10u /* Dọn bus: HIGH 10 µs sau stop */
  18:Sensor/dht11_sim.c **** 
  19:Sensor/dht11_sim.c **** #define DHT_TIM1_CC_IRQ_PRIO 6u
  20:Sensor/dht11_sim.c **** #define DHT_TIM2_IC_IRQ_PRIO 7u
  21:Sensor/dht11_sim.c **** 
  22:Sensor/dht11_sim.c **** /* Giới hạn độ rộng xung start hợp lệ từ host (µs) */
  23:Sensor/dht11_sim.c **** #define DHT_START_MIN 18000u
  24:Sensor/dht11_sim.c **** #define DHT_START_MAX 30000u
  25:Sensor/dht11_sim.c **** 
  26:Sensor/dht11_sim.c **** /**
  27:Sensor/dht11_sim.c ****  * enum dht11_tx_state - Các trạng thái của TX state machine
  28:Sensor/dht11_sim.c ****  * @TX_IDLE:      Bus rảnh, chờ host
  29:Sensor/dht11_sim.c ****  * @TX_RESP_LOW:  Đang kéo LOW 80 µs (response giai đoạn 1)
  30:Sensor/dht11_sim.c ****  * @TX_RESP_HIGH: Đang kéo HIGH 80 µs (response giai đoạn 2)
  31:Sensor/dht11_sim.c ****  * @TX_BIT_LOW:   Đang kéo LOW 50 µs preamble cho bit hiện tại
  32:Sensor/dht11_sim.c ****  * @TX_BIT_HIGH:  Đang kéo HIGH cho bit-0 (26 µs) hoặc bit-1 (70 µs)
ARM GAS  C:\Users\ADMIN\AppData\Local\Temp\ccOvpalB.s 			page 2


  33:Sensor/dht11_sim.c ****  * @TX_STOP_LOW:  Đang kéo LOW 50 µs (stop bit)
  34:Sensor/dht11_sim.c ****  * @TX_DONE:      Truyền xong, đang chuyển về chế độ nhận
  35:Sensor/dht11_sim.c ****  */
  36:Sensor/dht11_sim.c **** typedef enum
  37:Sensor/dht11_sim.c **** {
  38:Sensor/dht11_sim.c ****     TX_IDLE = 0,
  39:Sensor/dht11_sim.c ****     TX_RESP_LOW,
  40:Sensor/dht11_sim.c ****     TX_RESP_HIGH,
  41:Sensor/dht11_sim.c ****     TX_BIT_LOW,
  42:Sensor/dht11_sim.c ****     TX_BIT_HIGH,
  43:Sensor/dht11_sim.c ****     TX_STOP_LOW,
  44:Sensor/dht11_sim.c ****     TX_DONE
  45:Sensor/dht11_sim.c **** } dht11_tx_state_t;
  46:Sensor/dht11_sim.c **** 
  47:Sensor/dht11_sim.c **** /**
  48:Sensor/dht11_sim.c ****  * struct dht11_ctx - Context singleton của toàn module DHT11
  49:Sensor/dht11_sim.c ****  * @task_handle:       Handle của FreeRTOS task
  50:Sensor/dht11_sim.c ****  * @start_sem:         Semaphore báo hiệu start signal hợp lệ (give từ IC ISR)
  51:Sensor/dht11_sim.c ****  * @data_queue:        Queue nhận humidity/temperature mới từ application
  52:Sensor/dht11_sim.c ****  * @cfg:               Cấu hình được truyền vào qua dht11_sim_config()
  53:Sensor/dht11_sim.c ****  * @initialized:       Đặt thành 1 sau khi dht11_sim_config() thành công
  54:Sensor/dht11_sim.c ****  * @running:           Đặt thành 1 sau khi dht11_sim_run() thành công
  55:Sensor/dht11_sim.c ****  * @frame:             40-bit data frame [hum_int, hum_dec, tmp_int, tmp_dec, cksum]
  56:Sensor/dht11_sim.c ****  * @tx_state:          Trạng thái hiện tại của TX state machine (volatile, truy cập từ
  57:Sensor/dht11_sim.c ****  * @bit_index:         Vị trí bit đang truyền: 0..39, MSB-first (volatile, truy cập từ IS
  58:Sensor/dht11_sim.c ****  * @ic_awaiting_rise:  0 = đang chờ falling edge, 1 = đang chờ rising edge (volatile)
  59:Sensor/dht11_sim.c ****  * @ic_fall_capture:   Giá trị TIM2 capture tại falling edge (volatile)
  60:Sensor/dht11_sim.c ****  */
  61:Sensor/dht11_sim.c **** static struct dht11_ctx
  62:Sensor/dht11_sim.c **** {
  63:Sensor/dht11_sim.c ****     /* FreeRTOS */
  64:Sensor/dht11_sim.c ****     TaskHandle_t task_handle;
  65:Sensor/dht11_sim.c ****     SemaphoreHandle_t start_sem;
  66:Sensor/dht11_sim.c ****     QueueHandle_t data_queue;
  67:Sensor/dht11_sim.c **** 
  68:Sensor/dht11_sim.c ****     /* Cấu hình & trạng thái module */
  69:Sensor/dht11_sim.c ****     DHT11_Sim_Cfg_t cfg;
  70:Sensor/dht11_sim.c ****     uint8_t initialized;
  71:Sensor/dht11_sim.c ****     uint8_t running;
  72:Sensor/dht11_sim.c **** 
  73:Sensor/dht11_sim.c ****     /* DHT11 protocol frame */
  74:Sensor/dht11_sim.c ****     uint8_t frame[5];
  75:Sensor/dht11_sim.c **** 
  76:Sensor/dht11_sim.c ****     /* TX state machine — truy cập từ ISR */
  77:Sensor/dht11_sim.c ****     volatile dht11_tx_state_t tx_state;
  78:Sensor/dht11_sim.c ****     volatile uint8_t bit_index;
  79:Sensor/dht11_sim.c **** 
  80:Sensor/dht11_sim.c ****     /* Input capture state — truy cập từ ISR */
  81:Sensor/dht11_sim.c ****     volatile uint8_t ic_awaiting_rise;
  82:Sensor/dht11_sim.c ****     volatile uint16_t ic_fall_capture;
  83:Sensor/dht11_sim.c **** } g_dht11;
  84:Sensor/dht11_sim.c **** 
