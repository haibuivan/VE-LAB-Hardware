  87:Sensor/dht11_sim.c **** /**
  88:Sensor/dht11_sim.c ****  * prv_pa0_set_tx_mode - Chuyển PA0 sang open-drain output để phát data
  89:Sensor/dht11_sim.c ****  *
ARM GAS  C:\Users\ADMIN\AppData\Local\Temp\ccOvpalB.s 			page 3


  90:Sensor/dht11_sim.c ****  * Pre-set HIGH trước khi đổi mode để tránh glitch trên bus.
  91:Sensor/dht11_sim.c ****  */
  92:Sensor/dht11_sim.c **** static void prv_pa0_set_tx_mode(void)
  93:Sensor/dht11_sim.c **** {
  94:Sensor/dht11_sim.c ****     GPIO_SetBits(GPIOA, GPIO_Pin_0);
  95:Sensor/dht11_sim.c **** 
  96:Sensor/dht11_sim.c ****     GPIO_InitTypeDef gpio;
  97:Sensor/dht11_sim.c ****     gpio.GPIO_Pin = GPIO_Pin_0;
  98:Sensor/dht11_sim.c ****     gpio.GPIO_Mode = GPIO_Mode_Out_OD;
  99:Sensor/dht11_sim.c ****     gpio.GPIO_Speed = GPIO_Speed_50MHz;
 100:Sensor/dht11_sim.c ****     GPIO_Init(GPIOA, &gpio);
 101:Sensor/dht11_sim.c **** 
 102:Sensor/dht11_sim.c ****     GPIO_SetBits(GPIOA, GPIO_Pin_0); /* Idle HIGH */
 103:Sensor/dht11_sim.c **** }
 104:Sensor/dht11_sim.c **** 
 105:Sensor/dht11_sim.c **** /**
 106:Sensor/dht11_sim.c ****  * prv_pa0_set_rx_mode - Chuyển PA0 sang input pull-up để lắng nghe host
 107:Sensor/dht11_sim.c ****  *
 108:Sensor/dht11_sim.c ****  * Reset IC state và arm lại để bắt falling edge tiếp theo.
 109:Sensor/dht11_sim.c ****  */
 110:Sensor/dht11_sim.c **** static void prv_pa0_set_rx_mode(void)
 111:Sensor/dht11_sim.c **** {
 112:Sensor/dht11_sim.c ****     GPIO_InitTypeDef gpio;
 113:Sensor/dht11_sim.c ****     gpio.GPIO_Pin = GPIO_Pin_0;
 114:Sensor/dht11_sim.c ****     gpio.GPIO_Mode = GPIO_Mode_IPU;
 115:Sensor/dht11_sim.c ****     gpio.GPIO_Speed = GPIO_Speed_50MHz;
 116:Sensor/dht11_sim.c ****     GPIO_Init(GPIOA, &gpio);
 117:Sensor/dht11_sim.c **** 
 118:Sensor/dht11_sim.c ****     g_dht11.ic_awaiting_rise = 0;
 119:Sensor/dht11_sim.c ****     TIM2->CCER |= TIM_CCER_CC1P;             /* CC1P=1 → bắt falling edge */
 120:Sensor/dht11_sim.c ****     TIM_ClearITPendingBit(TIM2, TIM_IT_CC1); /* Xóa pending cũ tránh fire giả */
 121:Sensor/dht11_sim.c **** }
 122:Sensor/dht11_sim.c **** 
 123:Sensor/dht11_sim.c **** /* ------------------------------------------------------------------ */
 124:Sensor/dht11_sim.c **** 
 125:Sensor/dht11_sim.c **** /**
 126:Sensor/dht11_sim.c ****  * prv_oc_schedule - Lên lịch CC1 interrupt sau @us microsecond kể từ bây giờ
 127:Sensor/dht11_sim.c ****  * @us: Độ trễ tính bằng microsecond
 128:Sensor/dht11_sim.c ****  */
 129:Sensor/dht11_sim.c **** static inline void prv_oc_schedule(uint16_t us)
 130:Sensor/dht11_sim.c **** {
 131:Sensor/dht11_sim.c ****     TIM1->CCR1 = (uint16_t)(TIM1->CNT + us);
 132:Sensor/dht11_sim.c ****     TIM_ClearITPendingBit(TIM1, TIM_IT_CC1);
 133:Sensor/dht11_sim.c ****     TIM_ITConfig(TIM1, TIM_IT_CC1, ENABLE);
 134:Sensor/dht11_sim.c **** }
 135:Sensor/dht11_sim.c **** 
 136:Sensor/dht11_sim.c **** /* ------------------------------------------------------------------ */
 137:Sensor/dht11_sim.c **** 
 138:Sensor/dht11_sim.c **** /**
 139:Sensor/dht11_sim.c ****  * prv_frame_current_bit - Trả về giá trị (0 hoặc 1) của bit đang truyền
 140:Sensor/dht11_sim.c ****  *
 141:Sensor/dht11_sim.c ****  * Frame được truyền MSB-first trong từng byte.
 142:Sensor/dht11_sim.c ****  */
 143:Sensor/dht11_sim.c **** static inline uint8_t prv_frame_current_bit(void)
 144:Sensor/dht11_sim.c **** {
 145:Sensor/dht11_sim.c ****     uint8_t byte_idx = g_dht11.bit_index >> 3;
 146:Sensor/dht11_sim.c ****     uint8_t bit_pos = 7u - (g_dht11.bit_index & 0x07u);
ARM GAS  C:\Users\ADMIN\AppData\Local\Temp\ccOvpalB.s 			page 4


 147:Sensor/dht11_sim.c **** 
 148:Sensor/dht11_sim.c ****     return (g_dht11.frame[byte_idx] >> bit_pos) & 0x01u;
 149:Sensor/dht11_sim.c **** }
 150:Sensor/dht11_sim.c **** 
