 300:Sensor/dht11_sim.c **** /*
 301:Sensor/dht11_sim.c ****  * IRQ handlers — khai báo trong stm32f10x_it.c:
 302:Sensor/dht11_sim.c ****  *
 303:Sensor/dht11_sim.c ****  *   void TIM1_CC_IRQHandler(void) { dht11_tim1_cc_irq(); }
 304:Sensor/dht11_sim.c ****  *   void TIM2_IRQHandler(void)    { dht11_tim2_ic_irq(); }
